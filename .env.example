# Any random string — used to sign session JWTs
AUTH_SECRET=change-me-to-something-random

# SQLite path
DB_PATH=./data/stocktrack.sqlite

# Google OAuth — https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Stripe — credits pack (e.g. 10 analyses = €1)
STRIPE_SECRET_KEY=sk_live_or_test
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_CREDITS_10=price_...

# Protect the manual cron trigger endpoint
CRON_SECRET=change-me-random-string

# Production only
# BETTER_AUTH_URL=https://your-domain.com
